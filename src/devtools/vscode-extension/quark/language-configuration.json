{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "folding": {
    "offSide": true
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(if|elseif|else|for|while|when|fn|module|impl|struct)\\b.*(:|->)\\s*$",
    "decreaseIndentPattern": "^\\s*(elseif|else)\\b"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(if|elseif|else|for|while|when|module|struct|impl)\\b.*:\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*fn\\b.*->\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*.+->\\s*$",
      "action": { "indent": "indent" }
    }
  ]
}