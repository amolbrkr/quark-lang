{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Quark",
  "scopeName": "source.quark",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#function-definitions" },
    { "include": "#builtin-functions" },
    { "include": "#function-calls" },
    { "include": "#control-keywords" },
    { "include": "#keyword-values" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.quark",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.quark",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.quark",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.double.quark",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.quark",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "function-definitions": {
      "patterns": [
        {
          "comment": "Match: fn name(params)",
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function.quark" },
            "2": { "name": "entity.name.function.quark" }
          }
        },
        {
          "comment": "Match: name = fn(...) -> (lambda assignment)",
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(=)\\s*(fn)",
          "captures": {
            "1": { "name": "entity.name.function.quark" },
            "2": { "name": "keyword.operator.assignment.quark" },
            "3": { "name": "storage.type.function.quark" }
          }
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "comment": "I/O builtins",
          "match": "\\b(print|println|input)(?=\\s*\\()",
          "name": "support.function.builtin.quark"
        },
        {
          "comment": "Type conversion builtins",
          "match": "\\b(len|to_str|to_int|to_float|to_bool|type)(?=\\s*\\()",
          "name": "support.function.builtin.quark"
        },
        {
          "comment": "Result helper builtins",
          "match": "\\b(is_ok|is_err|unwrap)(?=\\s*\\()",
          "name": "support.function.builtin.quark"
        },
        {
          "comment": "Range builtin",
          "match": "\\b(range)(?=\\s*\\()",
          "name": "support.function.builtin.quark"
        },
        {
          "comment": "Math builtins",
          "match": "\\b(abs|min|max|sum|sqrt|floor|ceil|round)(?=\\s*\\()",
          "name": "support.function.builtin.quark"
        },
        {
          "comment": "String builtins",
          "match": "\\b(upper|lower|trim|contains|startswith|endswith|replace|concat|split)(?=\\s*\\()",
          "name": "support.function.builtin.quark"
        },
        {
          "comment": "List builtins",
          "match": "\\b(push|pop|get|set|insert|remove|slice|reverse)(?=\\s*\\()",
          "name": "support.function.builtin.quark"
        },
        {
          "comment": "Dict builtins",
          "match": "\\b(dget|dset)(?=\\s*\\()",
          "name": "support.function.builtin.quark"
        },
        {
          "comment": "Vector builtins",
          "match": "\\b(fillna|astype|to_vector|to_list)(?=\\s*\\()",
          "name": "support.function.builtin.quark"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "comment": "Match: identifier followed by opening paren (function call)",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.quark" }
          }
        }
      ]
    },
    "control-keywords": {
      "patterns": [
        {
          "name": "keyword.control.quark",
          "match": "\\b(if|else|elseif|for|while|when|in|use|module|break|continue)\\b"
        },
        {
          "name": "keyword.operator.logical.quark",
          "match": "\\b(and|or)\\b"
        },
        {
          "name": "storage.type.function.quark",
          "match": "\\b(fn)\\b"
        },
        {
          "name": "variable.language.wildcard.quark",
          "match": "\\b_\\b"
        }
      ]
    },
    "keyword-values": {
      "patterns": [
        {
          "name": "keyword.declaration.quark",
          "match": "\\b(dict|list|vector|result)\\b"
        },
        {
          "name": "keyword.other.result.quark",
          "match": "\\b(ok|err)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.quark",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.quark",
          "match": "\\b(null)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "comment": "Arrow must come before arithmetic to avoid - matching first",
          "name": "keyword.operator.arrow.quark",
          "match": "->"
        },
        {
          "name": "keyword.operator.pipe.quark",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.comparison.quark",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.exponent.quark",
          "match": "\\*\\*"
        },
        {
          "name": "keyword.operator.arithmetic.quark",
          "match": "\\+|\\-|\\*|\\/|%"
        },
        {
          "name": "keyword.operator.assignment.quark",
          "match": "="
        },
        {
          "name": "keyword.operator.unary.quark",
          "match": "\\!"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "comment": "Type annotations after colon: x: int, param: str",
          "match": "(?<=:\\s{0,4})\\b(int|float|str|bool|list|dict|vector|result|any)\\b",
          "name": "support.type.quark"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.quark",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.quark",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.property.quark",
          "match": "(?<=\\.)[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.quark",
          "match": ",|:|\\."
        },
        {
          "name": "punctuation.section.block.begin.quark",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.quark",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.parens.begin.quark",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.quark",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.quark",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.quark",
          "match": "\\]"
        }
      ]
    }
  }
}